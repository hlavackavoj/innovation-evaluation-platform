generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EVALUATOR
  USER
  VIEWER
}

enum PipelineStage {
  DISCOVERY
  VALIDATION
  MVP
  SCALING
  SPIN_OFF
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectPotentialLevel {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  MEETING
  CALL
  EMAIL
  NOTE
  WORKSHOP
  EVALUATION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum OrganizationType {
  UNIVERSITY
  FACULTY
  RESEARCH_CENTER
  INNOVATION_CENTER
  COMPANY
  INVESTOR
  PUBLIC_INSTITUTION
}

enum TeamStrength {
  TECHNICAL_ONLY
  BALANCED
  STRONG
}

enum BusinessReadiness {
  WEAK
  EMERGING
  STRONG
}

enum RecommendationStatus {
  PENDING
  COMPLETED
  DISMISSED
}

enum EmailProvider {
  GMAIL
  OUTLOOK
}

enum EmailConnectionStatus {
  ACTIVE
  REVOKED
  ERROR
}

enum SyncSchedule {
  DAILY
  WEEKLY
}

enum EmailSyncJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum EmailSyncJobTrigger {
  MANUAL
  SCHEDULED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ownedProjects Project[] @relation("ProjectOwner")
  activities    Activity[]
  assignedTasks Task[]
  emailConnections EmailAccountConnection[]
  syncJobs      EmailSyncJob[]
  auditLogs     AuditLog[]
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  website   String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  contacts  Contact[]
  projects  Project[]
}

model Contact {
  id             String           @id @default(cuid())
  name           String
  email          String?
  phone          String?
  role           String
  notes          String?
  organizationId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  projectLinks   ProjectContact[]
  emailAutomationLinks ProjectEmailAutomationContact[]
  tasks          Task[]
}

model Project {
  id                String                @id @default(cuid())
  title             String
  description       String
  field             String?
  stage             PipelineStage         @default(DISCOVERY)
  priority          ProjectPriority       @default(MEDIUM)
  potentialLevel    ProjectPotentialLevel @default(LOW) @map("potential_level")
  ipStatus          String?
  teamStrength      TeamStrength?
  businessReadiness BusinessReadiness?
  nextStep          String?
  nextStepDueDate   DateTime?
  lastContactAt     DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  organizationId    String?
  ownerUserId       String?
  organization      Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  owner             User?                 @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  contacts          ProjectContact[]
  activities        Activity[]
  tasks             Task[]
  recommendations   Recommendation[]
  documents         ProjectDocument[]
  emailAutomationSetting ProjectEmailAutomationSetting?
  emailLinks        ProjectEmailLink[]
  syncJobs          EmailSyncJob[]
}

model ProjectContact {
  projectId String
  contactId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([projectId, contactId])
}

model Activity {
  id           String       @id @default(cuid())
  projectId    String
  userId       String?
  type         ActivityType
  note         String
  emailMessageId String?    @unique
  emailParentId  String?
  aiAnalysis     Json?
  activityDate DateTime
  createdAt    DateTime     @default(now())
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceTasks   Task[]      @relation("TaskSourceActivity")
  emailMessage  EmailMessage? @relation(fields: [emailMessageId], references: [providerMessageId], onDelete: SetNull)
}

model Task {
  id               String          @id @default(cuid())
  projectId        String
  contactId        String?
  assignedToUserId String?
  sourceActivityId String?
  title            String
  description      String?
  status           TaskStatus      @default(TODO)
  priority         ProjectPriority @default(MEDIUM)
  dueDate          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact          Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo       User?           @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  sourceActivity   Activity?       @relation("TaskSourceActivity", fields: [sourceActivityId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([sourceActivityId])
}

model Recommendation {
  id            String               @id @default(cuid())
  title         String
  description   String
  ruleKey       String
  projectId     String
  status        RecommendationStatus @default(PENDING)
  suggestedRole String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ruleKey])
}

model Template {
  id          String           @id @default(cuid())
  name        String
  description String
  storagePath String           @map("fileUrl")
  targetStage PipelineStage
  createdAt   DateTime         @default(now())
  documents   ProjectDocument[]
}

model ProjectDocument {
  id         String    @id @default(cuid())
  projectId  String
  templateId String?
  name       String
  storagePath String   @map("fileUrl")
  createdAt  DateTime  @default(now())
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([templateId])
}

model EmailAccountConnection {
  id                    String                 @id @default(cuid())
  userId                 String
  provider               EmailProvider
  emailAddress           String?
  externalAccountId      String
  encryptedAccessToken   String
  encryptedRefreshToken  String?
  tokenExpiresAt         DateTime?
  scopes                 String[]
  status                 EmailConnectionStatus @default(ACTIVE)
  lastSyncedAt           DateTime?
  lastError              String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages               EmailMessage[]
  syncCursors            EmailSyncCursor[]
  syncJobs               EmailSyncJob[]

  @@unique([provider, externalAccountId])
  @@index([userId, status])
}

model EmailMessage {
  id                      String                 @id @default(cuid())
  accountConnectionId     String
  provider                EmailProvider
  providerMessageId       String                 @unique
  providerThreadId        String?
  providerParentMessageId String?
  internetMessageId       String?
  subject                 String?
  direction               String?
  participants            Json
  sentAt                  DateTime
  snippet                 String?
  bodyText                String?
  bodyHash                String?
  hasBody                 Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  accountConnection       EmailAccountConnection @relation(fields: [accountConnectionId], references: [id], onDelete: Cascade)
  projectLinks            ProjectEmailLink[]
  syncJobs                EmailSyncJob[]         @relation("EmailMessagesInJob")
  activities              Activity[]

  @@index([accountConnectionId, sentAt])
  @@index([providerThreadId])
}

model ProjectEmailLink {
  id             String       @id @default(cuid())
  projectId      String
  emailMessageId String
  confidence     Float
  reason         String
  createdAt      DateTime     @default(now())
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@unique([projectId, emailMessageId])
}

model EmailSyncCursor {
  id                  String                 @id @default(cuid())
  accountConnectionId String
  cursorKey           String
  cursorValue         String
  updatedAt           DateTime               @updatedAt
  accountConnection   EmailAccountConnection @relation(fields: [accountConnectionId], references: [id], onDelete: Cascade)

  @@unique([accountConnectionId, cursorKey])
}

model EmailSyncJob {
  id                  String                  @id @default(cuid())
  userId              String
  projectId           String?
  accountConnectionId String?
  trigger             EmailSyncJobTrigger
  status              EmailSyncJobStatus      @default(QUEUED)
  filterProvider      EmailProvider?
  filterDirection     String?
  filterFrom          DateTime?
  filterTo            DateTime?
  filterContactEmail  String?
  importedEmails      Int                     @default(0)
  matchedContacts     Int                     @default(0)
  suggestedContacts   Int                     @default(0)
  generatedTasks      Int                     @default(0)
  summary             Json?
  startedAt           DateTime?
  finishedAt          DateTime?
  error               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project             Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accountConnection   EmailAccountConnection? @relation(fields: [accountConnectionId], references: [id], onDelete: SetNull)
  importedMessages    EmailMessage[]          @relation("EmailMessagesInJob")

  @@index([userId, createdAt])
  @@index([projectId, status])
}

model ProjectEmailAutomationSetting {
  id             String      @id @default(cuid())
  projectId      String      @unique
  enabled        Boolean     @default(false)
  schedule       SyncSchedule?
  keywordAliases String[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contacts       ProjectEmailAutomationContact[]
  domains        ProjectEmailAutomationDomain[]
}

model ProjectEmailAutomationContact {
  settingId String
  contactId String
  createdAt DateTime                      @default(now())
  setting   ProjectEmailAutomationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  contact   Contact                       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([settingId, contactId])
}

model ProjectEmailAutomationDomain {
  id        String                        @id @default(cuid())
  settingId String
  domain    String
  createdAt DateTime                      @default(now())
  setting   ProjectEmailAutomationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique([settingId, domain])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}
